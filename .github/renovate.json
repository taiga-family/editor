{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": ["github>taiga-family/renovate-config"],
    "packageRules": [
        {
            "enabled": false,
            "matchPackageNames": ["/^@nx.*/", "/^nx$/"]
        },
        {
            "matchDepTypes": [
                "dependencies",
                "peerDependencies",
                "optionalDependencies"
            ],
            "semanticCommitType": "fix"
        }
    ]
}
